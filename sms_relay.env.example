# CyClaw SMS Relay v2 — environment template
# Copy to .env and fill in values. Never commit the real .env.

# Twilio credentials (from console.twilio.com)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM_NUMBER=+1YOUR_TWILIO_NUMBER

# Only your number(s) can query. E.164 format, comma-separated.
SMS_AUTH_WHITELIST=+1YOUR_CELL_NUMBER

# Relay bind address. Default is loopback-only, matching gate.py's own
# zero-trust posture. Set to 0.0.0.0 ONLY if this relay must accept Twilio
# webhooks directly from the public internet (no reverse proxy in front of
# it) — prefer fronting it with a reverse proxy / TLS terminator instead.
SMS_RELAY_HOST=127.0.0.1

# Relay server port (ngrok should tunnel this)
SMS_RELAY_PORT=8788

# SQLite session/dedupe DB path
SMS_DB_PATH=./sms_relay.db

# CyClaw gateway — localhost only, do NOT change to 0.0.0.0
CYCLAW_QUERY_URL=http://127.0.0.1:8787/query

# Session TTL in seconds (15 min default)
SMS_SESSION_TTL_SEC=900

# Webhook dedupe window in seconds (1 hour default)
SMS_DEDUPE_TTL_SEC=3600

# Max chars per SMS segment (Twilio hard cap ~1600, leave headroom)
SMS_SEGMENT_SIZE=1200

# Online providers the relay will offer during vault-miss confirm.
# Default: grok only (safe default for mode=offline repos).
# Add claude only if models.claude.enabled=true in config.yaml AND
# CLAUDE_API_KEY is set AND you are on a branch that supports it.
SMS_ALLOWED_ONLINE_PROVIDERS=grok

# Log level
SMS_LOG_LEVEL=INFO

# Immediate Twilio webhook ACK text
SMS_ACK_TEXT=Processing...

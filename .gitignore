# ==============================================================================
# CyClaw .gitignore
# ==============================================================================

# Python
__pycache__/
**/__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg

# Virtual environments
.venv/
venv/
env/
.env

# IDE
.vscode/
.idea/
*.swp
*.swo

# CyClaw runtime artifacts (never commit these)
index/
.emb_cache/
logs/
*.jsonl
data/personality/*.db
data/personality/*.db-shm
data/personality/*.db-wal
data/personality/soul.md.bak

# Corpus content (personal knowledge base — keep private)
# data/corpus/   <-- uncomment this line to gitignore your corpus

# Secrets
*.env
!cyclaw_telemetry_kill.env
.env.*
!.env.example

# OS
.DS_Store
Thumbs.db
*.lnk

# Windows shortcuts and junk
desktop.ini

# Zip archives
*.zip
*.tar.gz

# Codacy / CI artifacts
results.sarif
codacy-*.sarif

# rclone / Dropbox sync (never commit credentials or local sync state)
rclone.conf
**/rclone.conf
.rclone-state/

# Coverage artifacts
.coverage
htmlcov/

# Memory orchestrator runtime state (regenerable; snapshots themselves stay committable)
docs/memories/.orchestrator-state.json
# Derived working-set + index are rewritten from scratch on every orchestrator
# pass (like the state file above), so they are regenerable artifacts rather than
# source. The dated snapshot files (docs/memories/<date_time>.md) remain tracked.
docs/memories/INDEX.md
docs/memories/CONSOLIDATED.md
